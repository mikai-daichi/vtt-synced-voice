"""手動テスト用スクリプト。
vtt_synced_voice パッケージの動作確認に使用する。

使い方:
    cp test_run.py.example test_run.py
    # test_run.py を編集して audio_file / output_file を設定
    python test_run.py
"""
from vtt_synced_voice import transcribe

transcribe(
    # --- 入出力 ---
    audio_file="audio_input/sample.m4a",  # 入力音声ファイルのパス
    output_file="vtt_output/sample.vtt",  # 出力VTTファイルのパス

    # --- 書き起こし設定 ---
    language="ja",       # 言語コード: "ja" / "en" / "fr" / "de" など
    model="medium",      # モデル: "small"（高速・低精度）/ "medium" / "large-v2"（低速・高精度）
    device="cpu",        # 推論デバイス: "cpu" / "cuda"（NVIDIA GPU）

    # --- タイムスタンプ調整 ---
    margin_before=0.066, # onset検出後、さらに開始を早める秒数（デフォルト: 30fps×2フレーム）
    margin_after=0.0,    # 終了時刻を延ばす秒数

    # --- 無音検出 ---
    silence_threshold=0.001,
    # ピーク正規化後のRMS閾値。完全無音≈0.0、発話≈0.05〜1.0が目安。
    # ノイズが多い環境では大きくする（例: 0.005〜0.01）

    # --- キュー分割 ---
    max_gap_seconds=0.4,
    # 単語間の無音ギャップがこの秒数を超えたら新しいキューに分割する。
    # のんびり話す人・間が多い収録: 大きくする（例: 0.4〜0.5）
    # 早口・マシンガントーク: 小さくする（例: 0.1〜0.2）
    # 範囲の目安: 0.01〜0.5

    # --- 文単位マージ ---
    merge_sentences=True,
    # True: 形態素解析（日本語）または句読点（その他）で文単位にキューをマージする
    # False: WhisperXのアライメント結果をそのまま出力する
    min_cue_chars=50,
    # マージ後にこの文字数を超えるキューを後処理で分割する。
    # 句点（。！？!?）があれば全て分割、なければ形態素解析で文末+文頭パターンを検出して分割。
    # 0で無効。

    # --- テキスト出力 ---
    voice_only=False,
    # True: タイムスタンプなし・句点なしの.txtファイルを出力する（カット編集済み動画のテロップ用）
    # False: 通常のVTTファイルを出力する（デフォルト）

    # --- 誤変換置換 ---
    replacements=[
        # ["誤変換前", "正しい表記"],
        # ["ファイナルカットプロ", "Final Cut Pro"],
    ],
    # Whisperが誤認識しやすい固有名詞・専門用語を登録する。
    # 長い文字列を短い文字列より先に書くこと。

    # --- デバッグ ---
    verbose=True,        # onset検出の補正結果を表示する
    dry_run=False,       # True にするとファイルを書き出さずキューリストのみ返す

    # --- 開発者オプション ---
    write_unmerged=False,
    # merge_sentences=True のときのみ有効。
    # True: マージ前のキューを xxx_unmerged.vtt として追加出力する。
    # max_gap_seconds の調整やマージ結果の検証に使用する。
)
